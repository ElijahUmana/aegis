# ─── Required ────────────────────────────────────────────────────────────────
KERNEL_API_KEY=                # https://dashboard.onkernel.com/hackathon?code=KERNELHACKATHON2026
LIGHTCONE_API_KEY=             # Tzafon Lightcone — https://lightcone.ai/signup?campaign=HACKMAY9
TZAFON_API_KEY=                # alias of LIGHTCONE_API_KEY (legacy name; either works)
MINIMAX_API_KEY=               # MiniMax M2.7-highspeed verifier
MINIMAX_BASE_URL=https://api.minimaxi.com/v1   # confirmed reachable 2026-05-09

# ─── Optional ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=             # if set, JUDGE_MODEL defaults to Claude Opus 4.7; otherwise MiniMax
BREV_API_KEY=                  # https://brev.nvidia.com/org/f1k17b809/billing?coupon=tzafon-hack
NORTHSTAR_VLLM_URL=            # if self-hosting Northstar on Brev (e.g. http://brev-instance:8000/v1)
USE_LOCAL_NORTHSTAR=false

# ─── Backend / models (team convention) ──────────────────────────────────────
BROWSER_BACKEND=kernel
NORTHSTAR_MODEL=tzafon.northstar-cua-fast
VERIFIER_MODEL=MiniMax-M2.7-highspeed
# JUDGE_MODEL=claude-opus-4-7   # uncomment to override

# ─── CUA loop (team convention) ──────────────────────────────────────────────
CUA_DISPLAY_WIDTH=1280
CUA_DISPLAY_HEIGHT=720
CUA_MAX_STEPS=40
CUA_MAX_ATTEMPTS=5
CUA_TRAJ_DIR=trajectories

# ─── AEGIS knobs ─────────────────────────────────────────────────────────────
AEGIS_DEFAULT_N=4
AEGIS_VERIFY_EVERY_STEP=true
AEGIS_SECURITY_DEFAULT=block
AEGIS_AUDIT_LOG_PATH=./audit.jsonl
OPENSHELL_POLICY_PATH=aegis_core/security/openshell_policy.yaml

LOG_LEVEL=INFO
