# Required
KERNEL_API_KEY=                # https://dashboard.onkernel.com/hackathon?code=KERNELHACKATHON2026
TZAFON_API_KEY=                # https://lightcone.ai/signup?campaign=HACKMAY9 ($2,500 credits)
ANTHROPIC_API_KEY=             # Claude Opus 4.6 judge + Haiku 4.5 verifier fallback

# Optional — self-hosted Northstar on Brev (Stream A stretch)
BREV_API_KEY=                  # https://brev.nvidia.com/org/f1k17b809/billing?coupon=tzafon-hack
NORTHSTAR_VLLM_URL=            # e.g. http://brev-instance:8000/v1
USE_LOCAL_NORTHSTAR=false

# Optional — OpenShell / NemoClaw (Stream C)
OPENSHELL_POLICY_PATH=aegis_core/security/openshell_policy.yaml

# Optional — observability
WANDB_API_KEY=
LOG_LEVEL=INFO

# AEGIS knobs
AEGIS_DEFAULT_N=4              # wide-scaling parallelism per task
AEGIS_VERIFY_EVERY_STEP=true
AEGIS_SECURITY_DEFAULT=block   # block | approve | allow
AEGIS_AUDIT_LOG_PATH=./audit.jsonl
